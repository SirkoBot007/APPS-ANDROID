# Copy this file to `keystore.properties` (git-ignored) and fill in real values.
# Then place your release keystore at the app project root as `release-keystore.jks`.
#
# Generate the keystore ONCE and back it up safely — if you lose it you can never
# update this app on Google Play again. See PLAY-STORE.md at the repo root.
#
#   keytool -genkeypair -v -keystore release-keystore.jks -alias release \
#       -keyalg RSA -keysize 2048 -validity 10000

storeFile=../release-keystore.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=release
keyPassword=YOUR_KEY_PASSWORD
