# --- Android / Gradle (monorepo root) ---
# Each app is its own Gradle project; this root ignore covers them all.

# Build output
**/build/
**/.gradle/
**/captures/
**/.cxx/
**/.externalNativeBuild/

# Local config & secrets — never commit
**/local.properties
local.properties

# Release signing — NEVER commit keystores or their passwords
**/keystore.properties
keystore.properties
**/*.jks
**/*.keystore
*.jks
*.keystore

# Android Studio / IntelliJ
**/*.iml
.idea/
**/.idea/
*.hprof

# OS noise
.DS_Store
Thumbs.db

# Logs
*.log
